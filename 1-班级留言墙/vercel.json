{
  "version": 2,
  "builds": [
    { 
      "src": "server.js", 
      "use": "@vercel/node@3.0.0",
      "config": { 
        "maxLambdaSize": "15mb",
        "memory": 256,
        "timeout": 30
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js", "methods": ["GET", "POST", "DELETE", "OPTIONS"] },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "functions": {
    "server.js": {
      "memory": 256,
      "timeout": 30
    }
  }
}